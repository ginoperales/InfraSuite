{
  "name": "infrasuite-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "InfraSuite Monorepo for Architectural Suite of Applications",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "shared",
    "database"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
